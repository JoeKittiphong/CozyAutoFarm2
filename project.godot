; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="cozy farm2"
config/features=PackedStringArray("4.3", "Mobile")
run/main_scene="res://scenes/world/world.tscn"
config/icon="res://icon.svg"

[autoload]

GridManager="*res://systems/grid/grid_manager.gd"
FarmManager="*res://systems/farm/farm_manager.gd"
JobManager="*res://systems/farm/job_manager.gd"
InventoryManager="*res://systems/core/inventory_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

camera_up={
"deadzone": 0.5,
"events": []
}
camera_down={
"deadzone": 0.5,
"events": []
}
camera_left={
"deadzone": 0.5,
"events": []
}
camera_right={
"deadzone": 0.5,
"events": []
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
